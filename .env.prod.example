# Copy to .env.prod and fill in before: docker compose -f docker-compose.prod.yml --env-file .env.prod up -d

POSTGRES_DB=credora
POSTGRES_USER=credora
POSTGRES_PASSWORD=change-me-strong-password

JWT_SECRET=change-me-min-32-characters-production-secret
NEXTAUTH_SECRET=change-me-nextauth-production-secret-min-32-chars

NEXT_PUBLIC_API_URL=https://api.credora.example.com
NEXTAUTH_URL=https://credora.example.com
CORS_ORIGINS=https://credora.example.com

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

CREDIT_BUREAU_MODE=sandbox
SMS_MODE=sandbox
BACKUP_RETENTION_DAYS=14
